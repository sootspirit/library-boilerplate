    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1",
    "glob": "^13.0.6",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.16",
    "vite-plugin-lib-inject-css": "^2.2.2"
  }
}
