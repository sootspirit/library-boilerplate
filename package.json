{
  "name": "vite-vanilla-ts-library-template",
  "author": "Aleksandra Mętrak",
  "license": "MIT",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.js",
  "module": "./dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "watch": "tsc -b ./tsconfig.lib.json --watch & vite build --watch",
